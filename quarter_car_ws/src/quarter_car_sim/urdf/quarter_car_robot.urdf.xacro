<?xml version="1.0"?>
<!--
  Quarter-car robot URDF — 1/10-scale RC car, BFMC-inspired proportions [10].
  Chassis: 0.35 x 0.18 x 0.08 m, blue.
  Wheels x4: cylinder r=0.03 m l=0.02 m, black.
  Chassis joint: prismatic Z (vertical dynamics only).
  Wheels: visual-only fixed joints. No steering, no rotation.
  NO RViz2 markers. Gazebo is the only 3D visualizer.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="quarter_car">

  <xacro:property name="pi" value="3.14159265358979"/>

  <!-- Fixed world anchor -->
  <link name="base_link"/>

  <!-- Prismatic Z joint drives vertical position from ODE -->
  <joint name="chassis_joint" type="prismatic">
    <parent link="base_link"/>
    <child  link="chassis_link"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.5" upper="0.5" effort="10000" velocity="5"/>
  </joint>

  <!-- Chassis body: 0.35 x 0.18 x 0.08 m, blue -->
  <link name="chassis_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.18 0.08"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.3 0.8 1.0"/>
      </material>
    </visual>
    <inertial>
      <mass value="3.175"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Wheel macro: visual-only cylinders, r=0.03m l=0.02m, black -->
  <xacro:macro name="wheel" params="name x y">
    <joint name="${name}_joint" type="fixed">
      <parent link="chassis_link"/>
      <child  link="${name}_link"/>
      <origin xyz="${x} ${y} -0.05" rpy="${pi/2} 0 0"/>
    </joint>
    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="0.03" length="0.02"/>
        </geometry>
        <material name="black">
          <color rgba="0.1 0.1 0.1 1.0"/>
        </material>
      </visual>
    </link>
  </xacro:macro>

  <xacro:wheel name="fl_wheel" x=" 0.14" y=" 0.10"/>
  <xacro:wheel name="fr_wheel" x=" 0.14" y="-0.10"/>
  <xacro:wheel name="rl_wheel" x="-0.14" y=" 0.10"/>
  <xacro:wheel name="rr_wheel" x="-0.14" y="-0.10"/>

</robot>
